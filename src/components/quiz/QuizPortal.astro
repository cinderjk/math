---
import type { QuizCategory } from '../../data/quizBank';
import { algebraQuestionKinds } from '../../data/quizBank';

interface Props {
categories: QuizCategory[];
}

const { categories } = Astro.props as Props;
---

<section class="px-6 py-10 md:py-16">
	<div class="mx-auto max-w-7xl">
		<div class="mb-8 flex items-center justify-between gap-4">
			<a href="/"
				class="group inline-flex items-center gap-3 rounded-full border border-slate-200 bg-white px-4 py-2 shadow-sm transition-colors hover:border-sky-200 hover:bg-sky-50">
				<span
					class="flex h-9 w-9 items-center justify-center rounded-full bg-slate-950 text-white transition-transform group-hover:scale-105">
					<i class="fas fa-infinity text-sm"></i>
				</span>
				<span class="text-sm font-bold tracking-tight text-slate-900">MathVerse</span>
			</a>
			<a href="/#categories"
				class="inline-flex items-center rounded-full border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm transition-colors hover:border-sky-200 hover:bg-sky-50 hover:text-sky-700">
				<i class="fas fa-arrow-left mr-2"></i>Kembali ke beranda
			</a>
		</div>

		<div class="grid gap-6 lg:grid-cols-[1.15fr_0.85fr]">
			<div class="reveal">
				<span
					class="inline-flex rounded-full bg-violet-50 px-4 py-2 text-xs font-bold uppercase tracking-[0.35em] text-violet-700">Quiz
					Center</span>
				<h1 class="mt-6 text-4xl font-extrabold tracking-tight text-slate-950 md:text-6xl">Pilih kategori, lalu
					jawab 10 soal</h1>
				<p class="mt-5 max-w-2xl text-lg leading-relaxed text-slate-500">Setiap kategori berisi 10 soal. Urutan
					soal dan pilihan jawaban akan diacak setiap kali quiz dimulai.</p>
			</div>
			<div
				class="reveal rounded-[2rem] border border-slate-200 bg-white p-6 shadow-[0_20px_60px_rgba(15,23,42,0.08)]">
				<p class="text-sm font-semibold uppercase tracking-[0.35em] text-sky-700">Cara main</p>
				<ol class="mt-4 space-y-3 text-sm leading-relaxed text-slate-600">
					<li class="flex gap-3"><span
							class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-sky-50 text-xs font-bold text-sky-700">1</span><span>Pilih
							kategori yang ingin kamu latih.</span></li>
					<li class="flex gap-3"><span
							class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-sky-50 text-xs font-bold text-sky-700">2</span><span>Kerjakan
							10 soal yang diacak dari kategori tersebut.</span></li>
					<li class="flex gap-3"><span
							class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-sky-50 text-xs font-bold text-sky-700">3</span><span>Lihat
							pembahasan setelah menjawab tiap soal.</span></li>
				</ol>
			</div>
		</div>

		<div id="quizCategoryGrid" class="reveal mt-12 grid gap-5 md:grid-cols-2 xl:grid-cols-4">
			{categories.map((category) => (
			<button type="button"
				class="group rounded-[1.75rem] border border-slate-200 bg-white p-6 text-left shadow-[0_18px_40px_rgba(15,23,42,0.08)] transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_24px_55px_rgba(15,23,42,0.12)]"
				data-quiz-category={category.key} data-quiz-color={category.color}>
				<div class="flex items-center justify-between gap-3">
					<span class="rounded-full px-3 py-1 text-xs font-bold uppercase tracking-wide"
						style={`background:${category.color}15;color:${category.color}`}>{category.label}</span>
					<span class="text-xs font-semibold uppercase tracking-[0.3em] text-slate-400">10 soal</span>
				</div>
				<h2 class="mt-5 text-2xl font-extrabold tracking-tight text-slate-950">{category.title}</h2>
				<p class="mt-3 text-sm leading-relaxed text-slate-500">{category.description}</p>
				<div class="mt-6 flex items-center justify-between">
					<p class="text-sm font-semibold transition-colors group-hover:text-slate-900"
						style={`color:${category.color}`}>Mulai kategori</p>
					<i
						class="fas fa-arrow-right text-sm text-slate-400 transition-transform group-hover:translate-x-1"></i>
				</div>
			</button>
			))}
		</div>

		<div id="quizAppShell" class="mt-12 hidden">
			<div
				class="overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-[0_20px_60px_rgba(15,23,42,0.10)]">
				<div
					class="flex flex-col gap-4 border-b border-slate-200 px-6 py-6 md:flex-row md:items-center md:justify-between">
					<div>
						<p class="text-xs font-semibold uppercase tracking-[0.35em] text-sky-700">Kategori aktif : <span id="quizSidebarCategory"></span></p>
						<div class="mt-3 flex flex-wrap items-center gap-3">
							<span id="quizCategoryBadge"
								class="rounded-full bg-sky-50 px-3 py-1 text-xs font-bold uppercase tracking-wide text-sky-700">Algebra</span>
							<span id="quizQuestionCount" class="text-sm text-slate-500">10 soal siap dimainkan</span>
						</div>
					</div>
					<div class="flex flex-wrap gap-3">
						<button id="quizChangeCategory" type="button"
							class="rounded-full border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700 transition-colors hover:border-sky-200 hover:bg-sky-50 hover:text-sky-700">
							<i class="fas fa-layer-group mr-2"></i>Ganti kategori
						</button>
						<button id="quizRestartTop" type="button"
							class="rounded-full bg-slate-950 px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-slate-800">
							<i class="fas fa-rotate-right mr-2"></i>Ulangi kategori
						</button>
					</div>
				</div>
				<div class="h-1.5 bg-slate-100">
					<div id="quizProgress"
						class="h-full w-0 bg-gradient-to-r from-sky-500 to-violet-500 transition-all duration-300">
					</div>
				</div>
				<div class="grid gap-0 lg:grid-cols-5">
					<div class="p-6 md:p-8 lg:col-span-3">
						<div class="mb-6 flex items-center justify-between gap-4">
							<span id="quizNum" class="text-sm font-medium text-slate-400">Question 1 / 10</span>
							<div class="flex items-center gap-2"><i class="fas fa-star text-yellow-400"></i><span
									id="quizScore" class="text-lg font-bold text-slate-900">0</span></div>
						</div>
						<h2 id="quizQuestion" class="text-2xl font-extrabold tracking-tight text-slate-950 md:text-3xl">
						</h2>
						<div id="quizFormula" class="mt-4 rounded-2xl bg-slate-50 p-4 text-center"></div>
						<div id="quizOptions" class="mt-6 space-y-3"></div>
						
					</div>
					<aside class="lg:col-span-2 border-t border-slate-200 bg-slate-50/70 p-6 lg:border-l lg:border-t-0 lg:p-8">
						<p class="text-xs font-semibold uppercase tracking-[0.35em] text-slate-400">Progress</p>
						<div class="mt-4 space-y-4">
							<div class="rounded-2xl bg-white p-4 shadow-sm">
								<p class="text-sm text-slate-500">Score</p>
								<p id="quizSidebarScore" class="mt-1 text-3xl font-extrabold text-slate-950">0</p>
							</div>
							<div class="rounded-2xl bg-white p-4 shadow-sm">
								<p class="text-sm text-slate-500">Tips</p>
								<p class="mt-1 text-sm leading-relaxed text-slate-600">Baca pembahasan setelah memilih
									jawaban untuk memahami langkahnya.</p>
							</div>
							<div id="quizFeedback" class="hidden mt-6 rounded-2xl p-5"></div>
							<div class="mt-6 flex justify-end">
								<button id="quizNext" type="button"
									class="hidden rounded-2xl bg-sky-600 px-8 py-3 font-bold text-white shadow-md transition-colors hover:bg-sky-700">
									Next Question <i class="fas fa-arrow-right ml-2"></i>
								</button>
							</div>
						</div>
					</aside>
				</div>
			</div>
		</div>

		<div id="quizComplete"
			class="mt-10 hidden rounded-[2rem] border border-slate-200 bg-white p-8 text-center shadow-[0_20px_60px_rgba(15,23,42,0.10)] md:p-10">
			<div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-amber-50 text-amber-500">
				<i class="fas fa-trophy text-2xl"></i>
			</div>
			<h3 id="quizResultTitle" class="mt-5 text-3xl font-extrabold tracking-tight text-slate-950">Quiz selesai
			</h3>
			<p id="finalScore" class="mt-3 text-lg text-slate-500"></p>
			<div id="finalGrade" class="mt-6 text-5xl font-extrabold text-slate-950"></div>
			<div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
				<button id="quizRestart" type="button"
					class="rounded-2xl bg-slate-950 px-8 py-3 font-bold text-white transition-colors hover:bg-slate-800">
					<i class="fas fa-rotate-right mr-2"></i>Kerjakan kategori ini lagi
				</button>
				<button id="quizChooseAnother" type="button"
					class="rounded-2xl border border-slate-200 bg-white px-8 py-3 font-bold text-slate-700 transition-colors hover:border-sky-200 hover:bg-sky-50 hover:text-sky-700">
					<i class="fas fa-layer-group mr-2"></i>Pilih kategori lain
				</button>
			</div>
		</div>

		<script type="application/json" id="quiz-bank" set:html={JSON.stringify(categories)}></script>
		<script type="application/json" id="quiz-algebra-kinds" set:html={JSON.stringify(algebraQuestionKinds)}>
		</script>
		<script type="module" src="/js/shared.js"></script>
		<script type="module" src="/js/quiz-portal.js"></script>
	</div>
</section>