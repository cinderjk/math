			<div class="reveal group cursor-pointer rounded-[1.75rem] border border-slate-100 bg-white p-8 shadow-[0_18px_40px_rgba(15,23,42,0.10)] transition-transform duration-300 hover:-translate-y-2 hover:scale-[1.015] hover:shadow-[0_24px_60px_rgba(15,23,42,0.14)]" onclick="jumpTo('#geometry')">
