<section id="geometry" class="graph-paper px-6 py-24">
	<div class="mx-auto max-w-7xl">
		<div class="reveal mb-14 text-center">
			<p class="text-sm font-semibold uppercase tracking-[0.35em] text-emerald-700">Hands-On Geometry</p>
			<h2 class="mt-3 text-4xl font-extrabold tracking-tight md:text-5xl">Draggable Triangle Lab</h2>
			<p class="mx-auto mt-4 max-w-2xl text-slate-500">Drag the vertices to reshape the triangle. Measurements update live.</p>
		</div>
		<div class="grid items-start gap-8 lg:grid-cols-5 reveal">
			<div class="canvas-wrap lg:col-span-3">
				<canvas id="geoCanvas" class="block h-[460px] w-full touch-none"></canvas>
			</div>
			<div class="space-y-5 rounded-[1.75rem] border border-slate-100 bg-white p-8 shadow-[0_18px_45px_rgba(15,23,42,0.10)] lg:col-span-2">
				<div class="grid grid-cols-2 gap-4 text-sm">
					<div class="rounded-2xl bg-slate-50 p-4"><p class="text-slate-500">AB</p><p class="mt-1 text-lg font-bold"><span id="sideAB">0.00</span></p></div>
					<div class="rounded-2xl bg-slate-50 p-4"><p class="text-slate-500">BC</p><p class="mt-1 text-lg font-bold"><span id="sideBC">0.00</span></p></div>
					<div class="rounded-2xl bg-slate-50 p-4"><p class="text-slate-500">AC</p><p class="mt-1 text-lg font-bold"><span id="sideAC">0.00</span></p></div>
					<div class="rounded-2xl bg-slate-50 p-4"><p class="text-slate-500">Type</p><p class="mt-1 text-lg font-bold"><span id="triType">Acute, Scalene</span></p></div>
				</div>
				<div class="grid grid-cols-3 gap-4 text-sm">
					<div class="rounded-2xl border border-slate-100 p-4"><p class="text-slate-500">Angle A</p><p class="mt-1 text-lg font-bold"><span id="angleA">0.0°</span></p></div>
					<div class="rounded-2xl border border-slate-100 p-4"><p class="text-slate-500">Angle B</p><p class="mt-1 text-lg font-bold"><span id="angleB">0.0°</span></p></div>
					<div class="rounded-2xl border border-slate-100 p-4"><p class="text-slate-500">Angle C</p><p class="mt-1 text-lg font-bold"><span id="angleC">0.0°</span></p></div>
				</div>
				<div class="grid grid-cols-2 gap-4 text-sm">
					<div class="rounded-2xl bg-sky-50 p-4"><p class="text-sky-700">Perimeter</p><p class="mt-1 text-lg font-bold text-sky-900"><span id="perimeter">0.00</span></p></div>
					<div class="rounded-2xl bg-emerald-50 p-4"><p class="text-emerald-700">Area</p><p class="mt-1 text-lg font-bold text-emerald-900"><span id="area">0</span></p></div>
				</div>
				<div class="rounded-2xl border border-slate-100 bg-slate-50 p-4">
					<p class="text-sm font-semibold text-slate-700">Area Formula</p>
					<div id="areaFormula" class="mt-2"></div>
				</div>
			</div>
		</div>
	</div>
</section>
