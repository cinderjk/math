---
import BaseHead from '../components/BaseHead.astro';
import SiteHeader from '../components/sections/SiteHeader.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import CategoriesSection from '../components/sections/CategoriesSection.astro';
import PlotterSection from '../components/sections/PlotterSection.astro';
import GeometrySection from '../components/sections/GeometrySection.astro';
import QuizSection from '../components/sections/QuizSection.astro';
import SiteFooter from '../components/sections/SiteFooter.astro';
import PageScripts from '../components/PageScripts.astro';

const pageTitle = 'MathVerse — Visual Math Explorer';
const pageDescription = 'Explore algebra, geometry, statistics, and probability through interactive visualizations.';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={pageTitle} description={pageDescription} />
	</head>
	<body class="overflow-x-hidden bg-slate-50 text-slate-900 antialiased">
		<SiteHeader />
		<main id="top">
			<HeroSection />
			<CategoriesSection />
			<PlotterSection />
			<GeometrySection />
			<QuizSection />
		</main>
		<SiteFooter />
		<PageScripts />
	</body>
</html>